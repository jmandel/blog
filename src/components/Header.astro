---
---

<header class="header">
  <a href="/blog" class="logo" aria-label="Interop Blog by Josh Mandel, MD">
    <div class="logo-wrap" id="logoWrap">
      <canvas id="graph" width="156" height="156"></canvas>
      <div class="text-block">
        <h1>Interop <span>Blog</span></h1>
        <div class="byline">by Josh Mandel, MD</div>
      </div>
    </div>
  </a>
  <p class="logo__tagline">Musings on healthcare IT, FHIR, EHR systems, and digital health innovation</p>
  <div class="egg-toast" id="toast">🔥 FHIR in the hole!</div>
</header>

<style>
  .header {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    padding: 1.5rem 0 0.5rem;
    position: relative;
  }

  .logo {
    display: flex;
    justify-content: center;
    text-decoration: none;
    color: inherit;
  }

  .logo-wrap {
    display: flex;
    align-items: center;
    gap: 24px;
    user-select: none;
  }

  canvas {
    display: block;
    cursor: default;
  }

  .text-block {
    display: flex;
    flex-direction: column;
    gap: 4px;
    /* Fixed width so a DM-Sans font swap can't reflow the flex row and
       shift the canvas sideways. Sized to fit "Interop Blog" at 52px
       with a comfortable margin. */
    width: 340px;
  }

  .text-block h1 {
    font-size: 52px;
    font-weight: 700;
    letter-spacing: -1px;
    color: #1a2a3a;
    line-height: 1;
    margin: 0;
    font-family: 'DM Sans', sans-serif;
    white-space: nowrap;
  }

  .text-block h1 span {
    font-weight: 400;
    color: #3b8ec2;
  }

  .text-block .byline {
    font-size: 24px;
    color: #8a9bae;
    letter-spacing: 0.3px;
    font-family: 'DM Sans', sans-serif;
  }

  .logo__tagline {
    margin: 0;
    font-size: 1.05rem;
    color: #64748b;
    text-align: center;
  }

  .egg-toast {
    position: fixed;
    top: 24px;
    left: 50%;
    transform: translateX(-50%) translateY(-60px);
    background: #ffffff;
    color: #1a2a3a;
    padding: 10px 20px;
    border-radius: 10px;
    border: 1px solid rgba(59, 142, 194, 0.35);
    box-shadow: 0 10px 28px rgba(15, 23, 42, 0.14);
    font-size: 13px;
    font-weight: 500;
    font-family: 'DM Sans', sans-serif;
    letter-spacing: 0.3px;
    opacity: 0;
    transition: all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
    pointer-events: none;
    white-space: nowrap;
    z-index: 100;
  }

  .egg-toast.show {
    opacity: 1;
    transform: translateX(-50%) translateY(0);
  }

  @keyframes eggPulse {
    0% { transform: scale(1); opacity: 1; }
    50% { transform: scale(1.15); opacity: 0.7; }
    100% { transform: scale(1); opacity: 1; }
  }

  :global(.egg-active) canvas {
    animation: eggPulse 0.3s ease;
  }

  @media (max-width: 640px) {
    .logo-wrap {
      gap: 12px;
    }

    canvas {
      width: 80px !important;
      height: 80px !important;
    }

    .text-block {
      width: 230px;
    }

    .text-block h1 {
      font-size: 36px;
    }

    .text-block .byline {
      font-size: 16px;
    }

    .logo__tagline {
      font-size: 0.95rem;
    }
  }
</style>

<script is:inline>
  // Inline (not bundled/deferred) so this runs synchronously as the body
  // is parsed — the canvas is drawn before first paint, no pop-in.
  (function () {
    var canvas = document.getElementById('graph');
    var ctx = canvas.getContext('2d');
    var SIZE = 120;
    var SCALE = 1.3;
    var dpr = window.devicePixelRatio || 1;
    var displaySize = Math.round(SIZE * SCALE);
    canvas.width = displaySize * dpr;
    canvas.height = displaySize * dpr;
    canvas.style.width = displaySize + 'px';
    canvas.style.height = displaySize + 'px';
    ctx.scale(dpr * SCALE, dpr * SCALE);

    var C1 = '#2a6f9e';
    var C2 = '#7cc4e8';
    var EASTER_EGG_NODE = 5;

    var nodes = [
      { x: 20, y: 35, r: 4.5, c: C1 },
      { x: 10, y: 62, r: 4,   c: C2 },
      { x: 35, y: 14, r: 4,   c: C1 },
      { x: 42, y: 52, r: 3.5, c: C2 },
      { x: 25, y: 84, r: 3.5, c: C1 },
      { x: 60, y: 35, r: 6,   c: C1 },
      { x: 55, y: 72, r: 4.5, c: C2 },
      { x: 78, y: 16, r: 4,   c: C2 },
      { x: 100, y: 35, r: 4.5, c: C1 },
      { x: 82, y: 56, r: 3.5, c: C2 },
      { x: 98, y: 74, r: 4,   c: C1 },
      { x: 75, y: 92, r: 3.5, c: C2 },
      { x: 112, y: 56, r: 3.5, c: C1 },
      { x: 48, y: 102, r: 3.5, c: C1 },
    ];

    var edges = [
      [0,1],[0,2],[0,3],[1,3],[1,4],[2,3],[2,5],
      [3,5],[3,6],[4,6],[4,13],
      [5,7],[5,8],[5,9],[5,6],
      [6,11],[6,13],
      [7,8],[8,9],[8,12],[9,10],[9,12],
      [10,11],[10,12],
      [11,13],[7,2],
    ];

    var ANIM_DUR = 0.8;
    var elapsed = 0;
    var settled = false;
    var lastTime = 0;
    var animId = null;

    // Each packet is born at a source node and lands at a destination node,
    // fully contained within [0, ANIM_DUR]. These invariants hold regardless
    // of ANIM_DUR, so the total sequence length can be tuned freely.
    function createPacket(animDur) {
      var ei = Math.floor(Math.random() * edges.length);
      var pair = edges[ei];
      var a = pair[0], b = pair[1];
      var fwd = Math.random() > 0.5;
      var dur = animDur * (0.30 + Math.random() * 0.25);
      var start = Math.random() * Math.max(0, animDur - dur);
      return {
        from: nodes[fwd ? a : b],
        to: nodes[fwd ? b : a],
        start: start,
        dur: dur,
        size: 2.4 + Math.random() * 1.4,
        color: Math.random() > 0.5 ? C1 : C2,
      };
    }

    var packets = [];
    function initPackets() {
      packets = [];
      var count = 18 + Math.floor(Math.random() * 5);
      for (var i = 0; i < count; i++) packets.push(createPacket(ANIM_DUR));
    }

    // Smooth sine ease-in-out: zero velocity at the endpoints (packet
    // lands softly in its source/destination node), continuous
    // acceleration everywhere in between.
    function smoothEase(t) {
      if (t <= 0) return 0;
      if (t >= 1) return 1;
      return 0.5 - 0.5 * Math.cos(Math.PI * t);
    }

    function drawEdges() {
      ctx.strokeStyle = 'rgba(59,142,194,0.3)';
      ctx.lineWidth = 1.5;
      for (var i = 0; i < edges.length; i++) {
        var n1 = nodes[edges[i][0]], n2 = nodes[edges[i][1]];
        ctx.beginPath();
        ctx.moveTo(n1.x, n1.y);
        ctx.lineTo(n2.x, n2.y);
        ctx.stroke();
      }
    }

    function drawNodes() {
      for (var i = 0; i < nodes.length; i++) {
        var n = nodes[i];
        ctx.beginPath();
        ctx.arc(n.x, n.y, n.r, 0, Math.PI * 2);
        ctx.fillStyle = n.c;
        ctx.fill();
      }
    }

    function drawStatic() {
      ctx.clearRect(0, 0, SIZE, SIZE);
      drawEdges();
      drawNodes();
    }

    function frame(ts) {
      if (!lastTime) lastTime = ts;
      var dt = Math.min((ts - lastTime) / 1000, 0.05);
      lastTime = ts;
      elapsed += dt;

      ctx.clearRect(0, 0, SIZE, SIZE);
      drawEdges();

      for (var i = 0; i < packets.length; i++) {
        var p = packets[i];
        if (elapsed < p.start) continue;
        if (elapsed > p.start + p.dur) continue;
        var localT = (elapsed - p.start) / p.dur;
        var eased = smoothEase(localT);
        var x = p.from.x + (p.to.x - p.from.x) * eased;
        var y = p.from.y + (p.to.y - p.from.y) * eased;
        ctx.beginPath();
        ctx.arc(x, y, p.size, 0, Math.PI * 2);
        ctx.fillStyle = p.color;
        ctx.globalAlpha = 0.8;
        ctx.fill();
        ctx.globalAlpha = 1;
      }

      drawNodes();

      if (elapsed > ANIM_DUR && !settled) {
        settled = true;
        drawStatic();
        return;
      }
      if (!settled) animId = requestAnimationFrame(frame);
    }

    // --- Easter egg ---
    canvas.addEventListener('click', function (e) {
      e.preventDefault();
      e.stopPropagation();
      var rect = canvas.getBoundingClientRect();
      var sx = SIZE / rect.width;
      var sy = SIZE / rect.height;
      var mx = (e.clientX - rect.left) * sx;
      var my = (e.clientY - rect.top) * sy;
      var hub = nodes[EASTER_EGG_NODE];
      if (Math.hypot(mx - hub.x, my - hub.y) < hub.r + 6) triggerEasterEgg();
    });

    var eggBurstPackets = [];
    var eggElapsed = 0;
    var eggLastTime = 0;

    function triggerEasterEgg() {
      var toast = document.getElementById('toast');
      if (toast) toast.classList.add('show');
      setTimeout(function () { if (toast) toast.classList.remove('show'); }, 2000);
      var wrap = document.getElementById('logoWrap');
      if (wrap) wrap.classList.add('egg-active');
      setTimeout(function () { if (wrap) wrap.classList.remove('egg-active'); }, 350);

      var hub = nodes[EASTER_EGG_NODE];
      eggBurstPackets = [];
      for (var i = 0; i < edges.length; i++) {
        var a = edges[i][0], b = edges[i][1];
        var target = null;
        if (a === EASTER_EGG_NODE) target = nodes[b];
        else if (b === EASTER_EGG_NODE) target = nodes[a];
        if (!target) continue;
        for (var j = 0; j < 3; j++) {
          eggBurstPackets.push({
            from: hub, to: target, t: 0,
            dur: 0.2 + Math.random() * 0.15,
            delay: j * 0.05,
            size: 2 + Math.random() * 1.5,
            color: j % 2 === 0 ? '#e8943b' : '#e85b3b',
            done: false, elapsed: 0,
          });
        }
      }
      eggElapsed = 0;
      eggLastTime = 0;
      requestAnimationFrame(eggFrame);
    }

    function eggFrame(ts) {
      if (!eggLastTime) eggLastTime = ts;
      var dt = Math.min((ts - eggLastTime) / 1000, 0.05);
      eggLastTime = ts;
      eggElapsed += dt;
      drawStatic();

      var allDone = true;
      for (var i = 0; i < eggBurstPackets.length; i++) {
        var p = eggBurstPackets[i];
        if (p.done) continue;
        if (eggElapsed < p.delay) { allDone = false; continue; }
        p.elapsed = (p.elapsed || 0) + dt;
        p.t = Math.min(p.elapsed / p.dur, 1);
        if (p.t >= 1) { p.done = true; continue; }
        allDone = false;
        var x = p.from.x + (p.to.x - p.from.x) * p.t;
        var y = p.from.y + (p.to.y - p.from.y) * p.t;
        var alpha = 1;
        if (p.t < 0.1) alpha = p.t / 0.1;
        else if (p.t > 0.7) alpha = (1 - p.t) / 0.3;
        ctx.beginPath();
        ctx.arc(x, y, p.size, 0, Math.PI * 2);
        ctx.fillStyle = p.color;
        ctx.globalAlpha = alpha * 0.85;
        ctx.fill();
        ctx.globalAlpha = 1;
      }

      if (!allDone) requestAnimationFrame(eggFrame);
      else drawStatic();
    }

    // Draw the static graph synchronously so the canvas is populated on
    // the very first paint. Then start the packet animation.
    drawStatic();
    initPackets();
    animId = requestAnimationFrame(frame);
  })();
</script>
